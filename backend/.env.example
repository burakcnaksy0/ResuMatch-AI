# backend/.env.example
# Copy this file to .env and fill in your values

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/resumatch_dev

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI / OpenRouter ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# ─── App Limits ──────────────────────────────────────────────────────────────
MAX_CV_GENERATIONS_PER_HOUR=5
MAX_PROFILE_SIZE_KB=50
